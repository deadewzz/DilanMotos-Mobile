<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_background"
            android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="60dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white_rounded"
                android:orientation="vertical"
                android:padding="28dp">

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="¿Olvidaste tu contraseña?"
                    android:textAlignment="center"
                    android:textColor="#3B3BD6"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:text="Ingresa tu correo y te enviaremos un código de recuperación"
                    android:textAlignment="center"
                    android:textColor="#666666"
                    android:textSize="13sp" />

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Correo Electrónico"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            <EditText
                    android:id="@+id/etCorreoRecuperacion"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/input_border"
                    android:hint="correo@ejemplo.com"
                    android:inputType="textEmailAddress"
                    android:paddingEnd="14dp"
                    android:paddingStart="14dp"
                    android:textSize="14sp" />

            <Button
                    android:id="@+id/btnEnviarCodigo"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="#3B3BD6"
                    android:text="Enviar Código"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            <TextView
                    android:id="@+id/tvVolverLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:text="Volver al inicio de sesión"
                    android:textAlignment="center"
                    android:textColor="#3B3BD6"
                    android:textSize="13sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>