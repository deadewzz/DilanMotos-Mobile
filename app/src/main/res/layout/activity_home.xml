<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="#4F46E5"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:elevation="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DilanMotos"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvBienvenida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hola, Usuario 👋"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- BANNER HERO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4F46E5"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="36dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mantenimiento"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inteligente"
                android:textColor="#C7D2FE"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Botón IA destacado -->
            <Button
                android:id="@+id/btnRecomendacionesIA"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:text="🤖  VER RECOMENDACIONES DE IA"
                android:textColor="#4F46E5"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="24dp"
                android:letterSpacing="0.05"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- CURVA SEPARADORA -->
        <View
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:background="#F0F2F5" />

        <!-- SECCIÓN NUESTROS PRODUCTOS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nuestros Productos"
            android:textColor="#1E1B4B"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp" />

        <!-- Cards de categorías -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:weightSum="2">

            <!-- Card Motos -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏍️"
                        android:textSize="40sp"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Motos"
                        android:textColor="#1E1B4B"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnVerMotos"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text="Ver Catálogo"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#4F46E5"
                        android:stateListAnimator="@null" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Productos -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔧"
                        android:textSize="40sp"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Productos"
                        android:textColor="#1E1B4B"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnVerProductos"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text="Ver Catálogo"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#4F46E5"
                        android:stateListAnimator="@null" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- BOTÓN GESTIÓN DE SISTEMA (solo admin, se muestra/oculta desde código) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardGestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#EEF2FF"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚙️  Gestión de Sistema"
                    android:textColor="#4F46E5"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnGestionSistema"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Entrar"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4F46E5"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BANNER SOPORTE -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:text="📞  Soporte Técnico: 300-XXX-XXXX"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#10B981"
            android:stateListAnimator="@null" />

        <!-- CERRAR SESIÓN -->
        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            android:text="Cerrar Sesión"
            android:textColor="#EF4444"
            android:textSize="14sp"
            android:backgroundTint="#FEE2E2"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
