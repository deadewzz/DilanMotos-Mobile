<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginVertical="6dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="3dp">

    <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

        <!-- Información de la Moto (Izquierda) -->
        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toStartOf="@id/lytAcciones"
                android:layout_alignParentStart="true">

            <!-- Modelo -->
            <TextView
                    android:id="@+id/txtModeloMoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Modelo Moto"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"/>

            <!-- Marca -->
            <TextView
                    android:id="@+id/txtMarcaMoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Marca"
                    android:textSize="14sp"
                    android:textColor="@android:color/holo_blue_dark"
                    android:layout_marginTop="2dp"/>

            <!-- Año y Precio -->
            <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                <TextView
                        android:id="@+id/txtAnioMoto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Año: 2026"
                        android:textSize="14sp"
                        android:layout_marginEnd="16dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Botones de Acción (Derecha) -->
        <LinearLayout
                android:id="@+id/lytAcciones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

            <!-- Botón Editar -->
            <ImageView
                    android:id="@+id/btnEditarMoto"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:contentDescription="Editar" />

            <!-- Botón Eliminar -->
            <ImageView
                    android:id="@+id/btnEliminarMoto"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:contentDescription="Eliminar" />
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>