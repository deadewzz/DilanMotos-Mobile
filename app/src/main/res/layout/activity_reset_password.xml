<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_background"
            android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="60dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white_rounded"
                android:orientation="vertical"
                android:padding="28dp">

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Restablecer contraseña"
                    android:textAlignment="center"
                    android:textColor="#3B3BD6"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:text="Ingresa el código que recibiste en tu correo y tu nueva contraseña"
                    android:textAlignment="center"
                    android:textColor="#666666"
                    android:textSize="13sp" />

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Código de verificación"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            <EditText
                    android:id="@+id/etCodigo"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/input_border"
                    android:gravity="center"
                    android:hint="XXXXXX"
                    android:inputType="textCapCharacters"
                    android:letterSpacing="0.3"
                    android:maxLength="6"
                    android:paddingEnd="14dp"
                    android:paddingStart="14dp"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Nueva Contraseña"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            <EditText
                    android:id="@+id/etNuevaContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/input_border"
                    android:hint="Mínimo 6 caracteres"
                    android:inputType="textPassword"
                    android:paddingEnd="14dp"
                    android:paddingStart="14dp"
                    android:textSize="14sp" />

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Confirmar Contraseña"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            <EditText
                    android:id="@+id/etConfirmarContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="28dp"
                    android:background="@drawable/input_border"
                    android:hint="Repite tu contraseña"
                    android:inputType="textPassword"
                    android:paddingEnd="14dp"
                    android:paddingStart="14dp"
                    android:textSize="14sp" />

            <Button
                    android:id="@+id/btnCambiarContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="#3B3BD6"
                    android:text="Cambiar Contraseña"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            <TextView
                    android:id="@+id/tvVolverLoginReset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:text="Volver al inicio de sesión"
                    android:textAlignment="center"
                    android:textColor="#3B3BD6"
                    android:textSize="13sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>