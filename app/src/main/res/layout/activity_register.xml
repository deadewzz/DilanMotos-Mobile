<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="40dp">

        <!-- Card principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_white_rounded"
            android:padding="28dp">

            <!-- Título -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crea tu cuenta"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#3B3BD6"
                android:textAlignment="center"
                android:layout_marginBottom="6dp"/>

            <!-- Subtítulo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Únete al mejor taller para tu moto"
                android:textSize="14sp"
                android:textColor="#E67E22"
                android:textAlignment="center"
                android:layout_marginBottom="24dp"/>

            <!-- Nombre Completo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre Completo"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ej: Juan Perez"
                android:inputType="textPersonName"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/input_border"
                android:textSize="14sp"
                android:layout_marginBottom="18dp"/>

            <!-- Correo Electrónico -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Correo Electrónico"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etCorreo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="correo@ejemplo.com"
                android:inputType="textEmailAddress"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/input_border"
                android:textSize="14sp"
                android:layout_marginBottom="18dp"/>

            <!-- Contraseña -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contraseña"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etContrasena"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Mínimo 6 caracteres"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/input_border"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="20dp"/>

            <!-- Sección moto -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Información de tu Moto"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="16dp"/>

            <!-- Marca -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Marca de tu moto"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerMarca"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_border"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginBottom="18dp"/>

            <!-- Modelo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modelo (de nuestro catálogo)"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerModelo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_border"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginBottom="28dp"/>

            <!-- Botón registrar -->
            <Button
                android:id="@+id/btnRegistrar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Completar Registro"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#3B3BD6"
                android:layout_marginBottom="16dp"/>

            <!-- Link login -->
            <TextView
                android:id="@+id/tvIniciarSesion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Ya tienes cuenta? Inicia sesión"
                android:textSize="13sp"
                android:textColor="#666666"
                android:textAlignment="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
