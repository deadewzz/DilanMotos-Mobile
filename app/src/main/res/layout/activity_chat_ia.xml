<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F5F5F5">

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewChat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/layoutEnvio"
            android:padding="8dp"
            android:clipToPadding="false"/>

    <LinearLayout
            android:id="@+id/layoutEnvio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@android:color/white">

        <EditText
                android:id="@+id/edtFalla"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Describe la falla de tu moto aquí..."
                android:inputType="textLongMessage|textAutoCorrect"
                android:maxLines="3"/>

        <ImageButton
                android:id="@+id/btnEnviarChat"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_send"
                android:contentDescription="Enviar"/>
    </LinearLayout>
</RelativeLayout>